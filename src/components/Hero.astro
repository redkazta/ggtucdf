---
export interface Props {
  videoUrl: string;
  title: string;
}

const { videoUrl, title } = Astro.props;
---

<section class="hero" id="hero-root" aria-label="Hero">
  <div class="hero__placeholder" id="hero-placeholder"></div>
  <div class="hero__video-wrapper">
    <video
      id="hero-video"
      class="hero__video"
      muted
      loop
      playsinline
      autoplay
      disablepictureinpicture
      preload="auto"
    >
      <source src={videoUrl} type="video/mp4" />
    </video>
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">{title}</h1>
  </div>
</section>

<script>
  (function () {
    const video = document.getElementById("hero-video") as HTMLVideoElement | null;
    const placeholder = document.getElementById("hero-placeholder");
    if (!video || !placeholder) return;

    let revealed = false;

    function reveal() {
      if (revealed) return;
      revealed = true;
      video.style.opacity = "1";
      placeholder.style.opacity = "0";
    }

    function attemptPlay() {
      if (video.paused) {
        video.play().catch(function() {});
      }
    }

    // Immediate reveal if any data is available
    if (video.readyState >= 1) {
      reveal();
      attemptPlay();
    }

    // Multiple events that mean "video is ready to show"
    video.addEventListener("loadedmetadata", function() { reveal(); attemptPlay(); }, { once: true });
    video.addEventListener("loadeddata", function() { reveal(); attemptPlay(); }, { once: true });
    video.addEventListener("canplay", function() { reveal(); attemptPlay(); }, { once: true });
    video.addEventListener("canplaythrough", function() { reveal(); attemptPlay(); }, { once: true });

    // Periodic readyState check
    var checkInterval = setInterval(function() {
      if (video.readyState >= 1 || video.currentTime > 0) {
        reveal();
        attemptPlay();
        clearInterval(checkInterval);
      }
    }, 300);

    // Force reveal after 2s even if not fully loaded (show blurry/first frame)
    setTimeout(function() {
      reveal();
      attemptPlay();
      clearInterval(checkInterval);
    }, 2000);

    // Error handling
    video.addEventListener("error", function() {
      console.error("[Hero] Video error", video.error);
      clearInterval(checkInterval);
    }, { once: true });

    // Probabilistic pulse on title
    const titleEl = document.querySelector(".hero__title") as HTMLElement | null;
    if (titleEl) {
      const isMobile = window.innerWidth <= 767;
      function probPulse() {
        const r = Math.random();
        let targetScale: number;
        let durBase: number;
        if (isMobile) {
          durBase = 200 + Math.random() * 400;
          if (r < 0.55) {
            targetScale = 1.0 + Math.random() * 0.125;
          } else if (r < 0.82) {
            targetScale = 0.9 + Math.random() * 0.1;
          } else if (r < 0.94) {
            targetScale = 0.75 + Math.random() * 0.1;
          } else {
            targetScale = 0.45 + Math.random() * 0.15;
          }
        } else {
          durBase = 180 + Math.random() * 380;
          if (r < 0.40) {
            targetScale = 1.25 + Math.random() * 0.25;
          } else if (r < 0.70) {
            targetScale = 0.85 + Math.random() * 0.20;
          } else if (r < 0.88) {
            targetScale = 0.55 + Math.random() * 0.20;
          } else {
            targetScale = 1.05 + Math.random() * 0.35;
          }
        }
        const duration = durBase;
        titleEl.style.transition = `transform ${duration}ms cubic-bezier(0.45, 0, 0.55, 1)`;
        titleEl.style.transform = `scale(${targetScale})`;
        setTimeout(probPulse, duration);
      }
      probPulse();
    }
  })();
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: #000000;
  }

  .hero__placeholder {
    position: absolute;
    inset: 0;
    background: #000000;
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  .hero__video-wrapper {
    position: absolute;
    inset: -20%;
    width: 140%;
    height: 140%;
    z-index: 2;
    animation: hero-pulse 10s ease-in-out infinite;
    overflow: hidden;
  }
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.9s ease;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.8) 100%
    );
    z-index: 3;
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 1.5rem 1rem;
    pointer-events: none;
  }

  .hero__title {
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    text-transform: uppercase;
    color: #ffffff;
    font-size: clamp(1.1rem, 5.2vw, 3.4rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-align: center;
    -webkit-text-stroke-width: 0.6px;
    -webkit-text-stroke-color: #990000;
    text-shadow:
      0 0 8px rgba(255, 0, 0, 0.45),
      0 0 24px rgba(200, 0, 0, 0.25),
      0 0 48px rgba(150, 0, 0, 0.12),
      0 6px 40px rgba(0, 0, 0, 0.95);
    margin: 0 auto;
    width: 80vw;
    min-width: 40vw;
    max-width: 90vw;
    white-space: nowrap;
    overflow: visible;
    will-change: transform;
    transform-origin: center center;
    display: inline-block;
  }

  @media (max-width: 767px) {
    .hero__title {
      font-size: clamp(0.5rem, 2.5vw, 0.8rem);
      white-space: nowrap;
      width: 80vw;
      min-width: 40vw;
      max-width: 90vw;
      overflow: visible;
      -webkit-text-stroke-width: 0.35px;
      transform-origin: center center;
      display: inline-block;
    }
  }

  @keyframes hero-pulse {
    0%   { transform: scale(1) translate(0%, 0%); }
    25%  { transform: scale(1.05) translate(-1%, 1%); }
    50%  { transform: scale(1.35) translate(2%, -2%); }
    75%  { transform: scale(1.08) translate(-1%, 1%); }
    100% { transform: scale(1) translate(0%, 0%); }
  }
</style>
