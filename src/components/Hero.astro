---
export interface Props {
  videoUrl: string;
  title: string;
}

const { videoUrl, title } = Astro.props;
---

<section class="hero" id="hero-root" data-video-url={videoUrl} aria-label="Hero">
  <div class="hero__placeholder" id="hero-placeholder"></div>
  <div class="hero__video-wrapper">
    <video
      id="hero-video"
      class="hero__video"
      muted
      loop
      playsinline
      disablepictureinpicture
      preload="none"
    ></video>
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">{title}</h1>
  </div>
</section>

<script>
  (function () {
    const root = document.getElementById("hero-root");
    const video = document.getElementById("hero-video") as HTMLVideoElement | null;
    const placeholder = document.getElementById("hero-placeholder");
    if (!root || !video || !placeholder) return;

    const videoUrl = root.getAttribute("data-video-url");
    if (!videoUrl) return;

    let loaded = false;

    function onVideoReady(blobUrl: string) {
      video.src = blobUrl;
      video.style.opacity = "1";
      placeholder.style.opacity = "0";
      void video.play().catch(() => {});
    }

    function loadVideo() {
      if (loaded) return;
      loaded = true;

      fetch(videoUrl)
        .then((res) => {
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          return res.blob();
        })
        .then((blob) => {
          const blobUrl = URL.createObjectURL(blob);
          onVideoReady(blobUrl);
        })
        .catch((err) => {
          console.error("[Hero] Video load failed:", err);
          placeholder.style.opacity = "1";
        });
    }

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              if (document.readyState === "loading") {
                document.addEventListener(
                  "DOMContentLoaded",
                  () => void loadVideo(),
                  { once: true }
                );
              } else {
                loadVideo();
              }

              // Probabilistic pulse: mobile starts 80%, favors 90%, rare 40% spikes
              const titleEl = document.querySelector(".hero__title") as HTMLElement | null;
              if (titleEl) {
                const isMobile = window.innerWidth <= 767;
                function probPulse() {
                  const r = Math.random();
                  let targetScale: number;
                  let durBase: number;
                  if (isMobile) {
                    durBase = 200 + Math.random() * 400; // 200-600ms, triple fast
                    if (r < 0.55) {
                      targetScale = 1.0 + Math.random() * 0.125; // 80% -> 90%, high probability
                    } else if (r < 0.82) {
                      targetScale = 0.9 + Math.random() * 0.1; // 72% -> 80%
                    } else if (r < 0.94) {
                      targetScale = 0.75 + Math.random() * 0.1; // 60% -> 68%
                    } else {
                      targetScale = 0.45 + Math.random() * 0.15; // 36% -> 48%, aggressive rare
                    }
                  } else {
                    durBase = 180 + Math.random() * 380; // 180-560ms, triple fast
                    if (r < 0.40) {
                      targetScale = 1.25 + Math.random() * 0.25; // 1.25-1.50x
                    } else if (r < 0.70) {
                      targetScale = 0.85 + Math.random() * 0.20; // 0.85-1.05x
                    } else if (r < 0.88) {
                      targetScale = 0.55 + Math.random() * 0.20; // 0.55-0.75x
                    } else {
                      targetScale = 1.05 + Math.random() * 0.35; // 1.05-1.40x
                    }
                  }
                  const duration = durBase;
                  titleEl.style.transition = `transform ${duration}ms cubic-bezier(0.45, 0, 0.55, 1)`;
                  titleEl.style.transform = `scale(${targetScale})`;
                  setTimeout(probPulse, duration);
                }
                probPulse();
              }
              observer.disconnect();
            }
          });
        },
        { rootMargin: "0px", threshold: 0.01 }
      );
      observer.observe(root);
    } else {
      loadVideo();
    }
  })();
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: #000000;
  }

  .hero__placeholder {
    position: absolute;
    inset: 0;
    background: #000000;
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  .hero__video-wrapper {
    position: absolute;
    inset: -20%;
    width: 140%;
    height: 140%;
    z-index: 2;
    animation: hero-pulse 10s ease-in-out infinite;
    overflow: hidden;
  }
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.9s ease;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.8) 100%
    );
    z-index: 3;
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 1.5rem 1rem;
    pointer-events: none;
  }

  .hero__title {
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    text-transform: uppercase;
    color: #ffffff;
    font-size: clamp(1.1rem, 5.2vw, 3.4rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-align: center;
    -webkit-text-stroke-width: 0.6px;
    -webkit-text-stroke-color: #990000;
    text-shadow:
      0 0 8px rgba(255, 0, 0, 0.45),
      0 0 24px rgba(200, 0, 0, 0.25),
      0 0 48px rgba(150, 0, 0, 0.12),
      0 6px 40px rgba(0, 0, 0, 0.95);
    margin: 0 auto;
    width: 80vw;
    min-width: 40vw;
    max-width: 90vw;
    white-space: nowrap;
    overflow: visible;
    will-change: transform;
    transform-origin: center center;
    display: inline-block;
  }

  @media (max-width: 767px) {
    .hero__title {
      font-size: clamp(0.5rem, 2.5vw, 0.8rem);
      white-space: nowrap;
      width: 80vw;
      min-width: 40vw;
      max-width: 90vw;
      overflow: visible;
      -webkit-text-stroke-width: 0.35px;
      transform-origin: center center;
      display: inline-block;
    }
  }

  @keyframes hero-pulse {
    0%   { transform: scale(1) translate(0%, 0%); }
    25%  { transform: scale(1.05) translate(-1%, 1%); }
    50%  { transform: scale(1.35) translate(2%, -2%); }
    75%  { transform: scale(1.08) translate(-1%, 1%); }
    100% { transform: scale(1) translate(0%, 0%); }
  }
</style>
