---
const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Artista", href: "/artista" },
  { label: "Música", href: "/musica" },
  { label: "Videos", href: "/videos" },
];
---

<header class="site-header">
  <a href="/" class="site-header__logo" aria-label="Inicio">
    <span class="site-header__logo-g">G</span><span class="site-header__logo-rest">ARGUT</span>
  </a>

  <nav class="site-header__nav" aria-label="Navegación principal">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="site-header__link"
        data-nav={item.href}
        aria-current={Astro.url.pathname === item.href ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>

  <button
    class="site-header__menu-btn"
    id="menuToggle"
    type="button"
    aria-label="Abrir menú"
    aria-expanded="false"
    aria-controls="mobileDrawer"
  >
    <span class="site-header__menu-line" aria-hidden="true"></span>
    <span class="site-header__menu-line" aria-hidden="true"></span>
    <span class="site-header__menu-line" aria-hidden="true"></span>
  </button>
</header>

<script is:inline>
  (function() {
    const links = document.querySelectorAll('.site-header__link[data-nav]');
    const path = window.location.pathname;
    links.forEach(function(link) {
      var href = link.getAttribute('href');
      if (href === '/' ? path === '/' : path.startsWith(href || '')) {
        link.classList.add('is-active');
        link.setAttribute('aria-current', 'page');
      }
    });
  })();
</script>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    padding: 0 1.25rem;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(12px) saturate(1.2);
    -webkit-backdrop-filter: blur(12px) saturate(1.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .site-header__logo {
    display: flex;
    align-items: baseline;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    transition: opacity 0.2s;
    line-height: 1;
  }
  .site-header__logo:hover { opacity: 0.75; }

  .site-header__logo-g {
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    font-size: 1.35rem;
    color: #ff3333;
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .site-header__logo-rest {
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    font-size: 1.15rem;
    color: #ffffff;
    letter-spacing: 0.06em;
    line-height: 1;
    margin-left: -0.05em;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  .site-header__link {
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    text-transform: uppercase;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.7rem;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  .site-header__link:hover { color: rgba(255, 255, 255, 0.85); }
  .site-header__link.is-active {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
  }

  .site-header__menu-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 40px; height: 40px;
    background: none;
    border: none;
    color: #ffffff;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: opacity 0.2s;
    padding: 0;
  }
  .site-header__menu-btn:hover { opacity: 0.6; }

  .site-header__menu-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }

  @media (min-width: 768px) {
    .site-header { height: 64px; padding: 0 2.5rem; }
    .site-header__logo-g { font-size: 1.6rem; }
    .site-header__logo-rest { font-size: 1.35rem; }
    .site-header__nav { display: flex; }
    .site-header__menu-btn { display: none; }
    .site-header__link { font-size: 0.78rem; padding: 0.45rem 0.85rem; }
  }
</style>
