---
const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Artista", href: "/artista" },
  { label: "Música", href: "/musica" },
  { label: "Videos", href: "/videos" },
];
---

<div class="drawer-overlay" id="drawerOverlay" aria-hidden="true"></div>
<aside class="drawer" id="mobileDrawer" aria-label="Menú de navegación" aria-hidden="true">
  <div class="drawer__header">
    <button
      class="drawer__close"
      id="drawerClose"
      type="button"
      aria-label="Cerrar menú"
    >
      <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" fill="currentColor">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path>
      </svg>
    </button>
  </div>

  <nav class="drawer__nav" aria-label="Navegación móvil">
    {navItems.map((item) => (
      <a href={item.href} class="drawer__link">{item.label}</a>
    ))}
  </nav>
</aside>

<script is:inline>
  (function () {
    const menuToggle = document.getElementById("menuToggle");
    const drawer = document.getElementById("mobileDrawer");
    const overlay = document.getElementById("drawerOverlay");
    const closeBtn = document.getElementById("drawerClose");
    if (!menuToggle || !drawer || !overlay || !closeBtn) return;

    function openDrawer() {
      drawer.classList.add("is-open");
      overlay.classList.add("is-visible");
      drawer.setAttribute("aria-hidden", "false");
      overlay.setAttribute("aria-hidden", "false");
      menuToggle.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
      drawer.classList.remove("is-open");
      overlay.classList.remove("is-visible");
      drawer.setAttribute("aria-hidden", "true");
      overlay.setAttribute("aria-hidden", "true");
      menuToggle.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }

    menuToggle.addEventListener("click", openDrawer);
    closeBtn.addEventListener("click", closeDrawer);
    overlay.addEventListener("click", closeDrawer);

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeDrawer();
    });

    // Close on link click
    drawer.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeDrawer);
    });
  })();
</script>

<style>
  .drawer-overlay {
    position: fixed;
    inset: 0;
    z-index: 210;
    background: rgba(0, 0, 0, 0.65);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .drawer-overlay.is-visible {
    opacity: 1;
    visibility: visible;
  }

  .drawer {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: min(280px, 80vw);
    z-index: 220;
    background: #050505;
    border-left: 1px solid rgba(255, 50, 50, 0.15);
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    padding: 1rem;
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.5);
  }
  .drawer.is-open {
    transform: translateX(0);
  }

  .drawer__header {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 2rem;
  }

  .drawer__close {
    width: 40px; height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: #ffffff;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: opacity 0.2s;
  }
  .drawer__close:hover { opacity: 0.7; }

  .drawer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .drawer__link {
    font-family: "Bebas Neue", sans-serif;
    text-transform: uppercase;
    font-size: 1.35rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    padding: 0.85rem 0.5rem;
    border-radius: 6px;
    letter-spacing: 0.06em;
    transition: color 0.2s, background 0.2s, text-shadow 0.3s ease;
    -webkit-tap-highlight-color: transparent;
    border: 1px solid transparent;
  }
  .drawer__link:hover {
    color: #ff3333;
    background: rgba(255, 50, 50, 0.06);
    border-color: rgba(255, 50, 50, 0.15);
    text-shadow: 0 0 16px rgba(255, 50, 50, 0.35);
  }

  @media (min-width: 768px) {
    .drawer, .drawer-overlay { display: none; }
  }
</style>
