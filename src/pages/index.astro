---
import Hero from "../components/Hero.astro";
import RegisterSW from "../components/RegisterSW.astro";
import {
  HERO_VIDEO_URL,
  TRACK_SRC,
  KAZTA_IG_LOGO,
  YOUTUBE_URL,
  SPOTIFY_URL,
  INSTAGRAM_URL,
  SITE_TITLE,
  SITE_DESCRIPTION,
} from "../data/siteConfig";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={SITE_DESCRIPTION} />
    <title>{SITE_TITLE}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap"
    />

    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        background: #000000;
        color: #f5f5f5;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        overflow-x: hidden;
        min-height: 100dvh;
      }
    </style>

    <style>
      .cta-stack {
        position: fixed;
        left: 50%;
        bottom: max(1.2rem, env(safe-area-inset-bottom, 0px));
        z-index: 100;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        width: max-content;
        max-width: 96vw;
        pointer-events: none;
      }
      .cta-stack > * { pointer-events: auto; }

      .cta-icon {
        display: block;
        line-height: 0;
        text-decoration: none;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        filter: drop-shadow(0 3px 12px rgba(0,0,0,0.55));
        transition: transform 0.15s ease, filter 0.2s;
      }
      .cta-icon:hover { filter: drop-shadow(0 4px 16px rgba(0,0,0,0.65)); transform: scale(1.06); }
      .cta-icon:active { transform: scale(0.96); }
      .cta-icon__logo { display: block; width: 88px; height: 88px; object-fit: contain; }
      @media (max-width: 767px) { .cta-icon__logo { width: 76px; height: 76px; } }
      @media (min-width: 1200px) { .cta-icon__logo { width: 96px; height: 96px; } }

      .cta-label {
        font-family: "Archivo Black", sans-serif;
        font-style: italic;
        text-transform: uppercase;
        color: #ffffff;
        text-align: center;
        line-height: 1.05;
        letter-spacing: 0.04em;
        text-shadow: 0 4px 18px rgba(0,0,0,0.9);
        pointer-events: none;
        user-select: none;
      }
      .cta-label--big {
        font-size: clamp(1.1rem, 3.2vmin, 1.6rem);
      }
      .cta-label--small {
        font-size: clamp(0.78rem, 2.2vmin, 1.05rem);
        color: #e0e0e0;
      }
      .cta-arrows {
        font-size: clamp(1rem, 2.6vmin, 1.4rem);
        letter-spacing: -0.1em;
        line-height: 1;
      }

      .cta-ig {
        position: fixed;
        right: max(0.75rem, env(safe-area-inset-right, 0px));
        bottom: max(0.75rem, env(safe-area-inset-bottom, 0px));
        z-index: 100; display: block; width: max-content;
        max-width: min(280px, 90vw); text-decoration: none;
        color: rgba(240,240,240,0.88); cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        filter: drop-shadow(0 2px 10px rgba(0,0,0,0.55));
        transition: transform 0.15s ease, filter 0.2s;
      }
      .cta-ig:hover { filter: drop-shadow(0 3px 14px rgba(0,0,0,0.7)); transform: scale(1.03); }
      .cta-ig:active { transform: scale(0.98); }
      .cta-ig__eyebrow { display: block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.02em; line-height: 1.1; margin-bottom: 0.15rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .cta-ig__logo { display: block; height: 52px; width: auto; max-width: 100%; object-fit: contain; object-position: left center; }
      @media (min-width: 768px) { .cta-ig__logo { height: 64px; } }

      .sound-cluster {
        position: fixed;
        top: max(0.5rem, env(safe-area-inset-top, 0px));
        left: max(0.5rem, env(safe-area-inset-left, 0px));
        z-index: 100; display: flex; align-items: center; gap: 0.1rem;
      }
      .sound-toggle {
        width: 44px; height: 44px; border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px; background: rgba(10,10,10,0.85); color: #e0e0e0;
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: background 0.2s, transform 0.1s;
      }
      .sound-toggle:hover { background: rgba(255,255,255,0.08); }
      .sound-toggle:active { transform: scale(0.95); }
      .sound-toggle svg { width: 22px; height: 22px; fill: currentColor; }

      .err-msg {
        position: fixed; bottom: calc(50% - 8rem); left: 50%;
        transform: translateX(-50%); z-index: 25; max-width: min(32rem, 92vw);
        text-align: center; font-size: 0.85rem; color: #f09090; pointer-events: none;
      }
    </style>
  </head>

  <body>
    <RegisterSW />
    <Hero videoUrl={HERO_VIDEO_URL} title={SITE_TITLE} />

    <p class="err-msg" id="err-msg" role="status"></p>

    <div class="sound-cluster">
      <button class="sound-toggle" id="soundToggle" type="button" aria-label="Activar o desactivar sonido">
        <svg id="soundOnIcon" viewBox="0 0 24 24" style="display:none" aria-hidden="true">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"></path>
        </svg>
        <svg id="soundOffIcon" viewBox="0 0 24 24" style="display:block" aria-hidden="true">
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"></path>
        </svg>
      </button>
    </div>

    <div class="cta-stack">
      <a href={SPOTIFY_URL} target="_blank" rel="noopener" class="cta-icon" aria-label="Escuchar en Spotify">
        <img class="cta-icon__logo" src="/brand/spotify.svg" width="88" height="88" alt="" decoding="async" />
      </a>

      <div class="cta-label cta-label--big">
        <span class="cta-arrows">&#171;&#171;</span> YO TE KIERO SOLO <span class="cta-arrows">&#187;&#187;</span>
      </div>
      <div class="cta-label cta-label--big" style="color:#ff3333;">OUT!!!</div>

      <a href={YOUTUBE_URL} target="_blank" rel="noopener" class="cta-icon" aria-label="Gargut en YouTube">
        <img class="cta-icon__logo" src="/brand/youtube.svg" width="88" height="88" alt="" decoding="async" />
      </a>

      <div class="cta-label cta-label--small">
        <span class="cta-arrows">&#8593;&#8593;</span> VER VISUALIZER <span class="cta-arrows">&#8593;&#8593;</span>
      </div>
    </div>

    <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="cta-ig" aria-label="Hecho por: young_kazta, abrir Instagram">
      <span class="cta-ig__eyebrow">Hecho por:</span>
      <img class="cta-ig__logo" src={KAZTA_IG_LOGO} width="400" height="120" alt="" decoding="async" />
    </a>

    <audio id="track" preload="auto" loop playsinline autoplay muted src={TRACK_SRC}></audio>

    <script>
      (function() {
        const audio = document.getElementById("track") as HTMLAudioElement | null;
        const btn = document.getElementById("soundToggle");
        const onIcon = document.getElementById("soundOnIcon") as HTMLElement | null;
        const offIcon = document.getElementById("soundOffIcon") as HTMLElement | null;
        if (!audio || !btn || !onIcon || !offIcon) return;

        let soundEnabled = false;
        function update() {
          onIcon.style.display = soundEnabled ? "block" : "none";
          offIcon.style.display = soundEnabled ? "none" : "block";
        }

        btn.addEventListener("click", () => {
          if (!soundEnabled) {
            soundEnabled = true;
            audio.muted = false;
            update();
            audio.play().catch(() => {});
          } else {
            soundEnabled = false;
            audio.muted = true;
            update();
          }
        });
      })();
    </script>
  </body>
</html>
