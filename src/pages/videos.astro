---
import ArtistLayout from "../layouts/ArtistLayout.astro";
import PageFooter from "../components/PageFooter.astro";
import { SPOTIFY_EMBED_ARTIST, SPOTIFY_EMBED_TRACK } from "../data/siteConfig";
---

<ArtistLayout title="Videos" description="Contenido de Garguttieneunchingodeferia — Spotify.">
  <section class="videos-page" aria-label="Contenido">
    <h1 class="page-title">Videos</h1>

    <div class="videos-empty">
      <div class="videos-empty__icon" aria-hidden="true">▶</div>
      <h2 class="videos-empty__title">Próximamente</h2>
      <p class="videos-empty__text">
        Los videos oficiales aparecerán aquí. Mientras tanto, escucha en Spotify.
      </p>
    </div>

    <div class="embed-block">
      <h2 class="embed-block__title">Escucha ahora</h2>
      <div class="embed-wrap">
        <iframe
          src={SPOTIFY_EMBED_TRACK}
          width="100%"
          height="152"
          style="border-radius:12px; border:0;"
          allow="encrypted-media"
          loading="lazy"
          title="YO TE KIERO SOLO en Spotify"
        ></iframe>
      </div>
    </div>

    <div class="embed-block">
      <h2 class="embed-block__title">Más del artista</h2>
      <div class="embed-wrap">
        <iframe
          src={SPOTIFY_EMBED_ARTIST}
          width="100%"
          height="360"
          style="border-radius:12px; border:0;"
          allow="encrypted-media"
          loading="lazy"
          title="Gargut en Spotify"
        ></iframe>
      </div>
    </div>
  </section>

  <PageFooter />
</ArtistLayout>

<style>
  .videos-page {
    padding: 1.5rem 1rem 3rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .page-title {
    font-family: "Bebas Neue", sans-serif;
    text-transform: uppercase;
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: #ffffff;
    letter-spacing: 0.04em;
    margin-bottom: 1.5rem;
    line-height: 1;
    text-shadow: 0 0 18px rgba(255, 50, 50, 0.4);
  }

  .videos-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .videos-empty__icon {
    font-size: 2.5rem;
    color: rgba(255, 255, 255, 0.12);
    line-height: 1;
  }

  .videos-empty__title {
    font-family: "Bebas Neue", sans-serif;f;
    text-transform: uppercase;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.02em;
  }

  .videos-empty__text {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.35);
    max-width: 320px;
    line-height: 1.55;
  }

  .embed-block {
    margin-bottom: 2rem;
  }

  .embed-block__title {
    font-family: "Bebas Neue", sans-serif;f;
    text-transform: uppercase;
    font-size: clamp(0.85rem, 2vw, 1.1rem);
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.02em;
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .embed-wrap {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
  }
</style>
