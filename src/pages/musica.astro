---
import ArtistLayout from "../layouts/ArtistLayout.astro";
import { DISCOGRAPHY, SPOTIFY_ARTIST_URL } from "../data/siteConfig";

const sorted = [...DISCOGRAPHY].sort((a, b) => {
  if (b.year !== a.year) return b.year - a.year;
  if (a.streams && b.streams) return b.streams - a.streams;
  if (a.streams) return -1;
  if (b.streams) return 1;
  return 0;
});

function formatStreams(n?: number) {
  if (!n) return null;
  if (n >= 1000) return `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}K`;
  return String(n);
}
---

<ArtistLayout title="Música" description="Discografía completa de Garguttieneunchingodeferia — singles 2025-2026.">
  <section class="music-page" aria-label="Discografía">
    <h1 class="page-title">Música</h1>

    <div class="discography-grid">
      {sorted.map((track) => (
        <a
          href={track.spotifyUrl}
          target="_blank"
          rel="noopener"
          class="track-card"
          aria-label={`Escuchar ${track.title} en Spotify`}
        >
          <div class="track-card__cover-wrap">
            {track.coverUrl ? (
              <img
                src={track.coverUrl}
                alt=""
                class="track-card__cover"
                width="300"
                height="300"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="track-card__cover-fallback">
                <span>{track.title.charAt(0)}</span>
              </div>
            )}
            <div class="track-card__overlay">
              <span class="track-card__play">▶</span>
            </div>
          </div>

          <div class="track-card__info">
            <h2 class="track-card__title">{track.title}</h2>
            <div class="track-card__meta">
              <span class="track-card__year">{track.year}</span>
              <span class="track-card__badge" data-type={track.type}>
                {track.type === "solo" ? "Solo" : "Colab"}
              </span>
              {track.streams ? (
                <span class="track-card__streams">{formatStreams(track.streams)} reprod.</span>
              ) : null}
            </div>
            {track.collaborators && track.collaborators.length > 0 && (
              <p class="track-card__collabs">
                {track.collaborators.join(", ")}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>

    <div class="music-footer">
      <a href={SPOTIFY_ARTIST_URL} target="_blank" rel="noopener" class="btn btn--outline">
        Ver todo en Spotify
      </a>
    </div>
  </section>
</ArtistLayout>

<style>
  .music-page {
    padding: 1.5rem 1rem 3rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .page-title {
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    text-transform: uppercase;
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: #ffffff;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .discography-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .discography-grid {
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1.25rem;
    }
  }

  .track-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.15s ease;
  }
  .track-card:hover { transform: translateY(-4px); }

  .track-card__cover-wrap {
    position: relative;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 0.6rem;
    background: #111;
  }

  .track-card__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .track-card__cover-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a0a0a 0%, #0a0a0a 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .track-card__cover-fallback span {
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    font-size: 3rem;
    color: rgba(255, 255, 255, 0.15);
    text-transform: uppercase;
  }

  .track-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .track-card:hover .track-card__overlay { opacity: 1; }

  .track-card__play {
    font-size: 1.8rem;
    color: #ffffff;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5));
    line-height: 1;
  }

  .track-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .track-card__title {
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .track-card__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .track-card__year {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .track-card__badge {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.5);
    line-height: 1;
  }
  .track-card__badge[data-type="solo"] {
    background: rgba(29, 185, 84, 0.12);
    color: rgba(29, 185, 84, 0.7);
  }

  .track-card__streams {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.35);
  }

  .track-card__collabs {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.35);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .music-footer {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-family: "Archivo Black", sans-serif;
    font-style: italic;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.15s ease, opacity 0.2s;
  }
  .btn:hover { transform: scale(1.04); opacity: 0.9; }
  .btn:active { transform: scale(0.97); }

  .btn--outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }
  .btn--outline:hover {
    border-color: rgba(255, 255, 255, 0.3);
    color: #ffffff;
  }
</style>
